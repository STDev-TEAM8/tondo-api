# ====================================
# AWS 설정
# ====================================

# AWS IAM 액세스 키 (IAM 콘솔에서 발급)
AWS_ACCESS_KEY_ID=AKIA000000000000000

# AWS IAM 시크릿 키
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here

# AWS 리전 (Bedrock 사용 가능한 리전)
# 사용 가능 리전: us-east-1, us-west-2, ap-northeast-1 등
AWS_REGION=us-east-1


# ====================================
# Bedrock 모델 ID
# ====================================

# 채팅 모델 (Claude)
# claude-3-5-sonnet:  anthropic.claude-3-5-sonnet-20241022-v2:0
# claude-3-haiku:     anthropic.claude-3-haiku-20240307-v1:0
# claude-3-opus:      anthropic.claude-3-opus-20240229-v1:0
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# 이미지 생성 모델
# titan:              amazon.titan-image-generator-v1
# stable diffusion:   stability.stable-diffusion-xl-v1
BEDROCK_IMAGE_MODEL_ID=amazon.titan-image-generator-v1


# ====================================
# 주의사항
# ====================================
# 1. 이 파일을 복사해서 .env 로 사용하세요
# 2. .env 파일은 절대 Git에 올리지 마세요 (.gitignore 에 추가 필수)
# 3. AWS 계정 발급 후 IAM > 사용자 > 액세스 키 에서 발급
# 4. IAM 권한: AmazonBedrockFullAccess 정책 필요